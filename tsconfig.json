{
    "compilerOptions": {
      "target": "ESNext",
      "useDefineForClassFields": true,
      "module": "ESNext",
      "moduleResolution": "Node",
      "strict": true,
      "jsx": "preserve",
      "allowSyntheticDefaultImports": true,
      "sourceMap": true,
      "resolveJsonModule": true,
      "isolatedModules": true,
      "esModuleInterop": true,
      "lib": ["ESNext", "DOM"],
      "skipLibCheck": true,
      "baseUrl": "./",
      "paths": { "@/*": ["src/*"] },
      "noImplicitAny": false,
      "allowJs": true,
      "types": ["vite/client", "vue"]  // Retirer ou ajuster les types si nécessaire
    },
    "include": ["src/**/*.js", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx","src/**/*.vue"],
    "references": [
      {
        "path": "./tsconfig.node.json"
      }
    ]
  }
  